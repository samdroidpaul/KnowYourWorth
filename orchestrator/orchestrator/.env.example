# Copy this file to ".env" (same folder) and fill in the real values.
# .env is used for local testing with `adk web`. For Cloud Run, set the same
# values on the deployed service (see the deploy notes in orchestrator/README.md).

# Use the Agent Platform (formerly Vertex AI) backend for the Gemini model:
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=global

# Values the knowledge tool needs to reach your published data agent:
PROJECT_ID=your-project-id
DATA_AGENT_LOCATION=global
DATA_AGENT_ID=your-published-data-agent-id

# Model Armor (optional — content-safety layer, screens every prompt/response
# for prompt injection, jailbreak attempts, and harmful content). Unset either
# var and the orchestrator no-ops the check entirely; nothing else is affected.
# See docs/model-armor-monitoring.md for setup, and note the region gotcha
# documented there before assuming any region works.
MODEL_ARMOR_TEMPLATE=
MODEL_ARMOR_LOCATION=australia-southeast2
