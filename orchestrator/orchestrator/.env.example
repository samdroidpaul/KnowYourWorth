# Copy to `.env` (same folder) and fill in the values from your GCP project.
# `.env` is used for local testing with `adk web`. On Cloud Run, the same
# variables are set with `--set-env-vars` at deploy time.

# Route the ADK model through Vertex AI (Agent Platform):
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=global

# Values the knowledge tool needs to reach your published data agent:
PROJECT_ID=your-project-id
DATA_AGENT_LOCATION=global
DATA_AGENT_ID=your-published-data-agent-id
