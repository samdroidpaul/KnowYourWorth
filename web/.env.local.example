# Copy to `.env.local` and fill in.
#
# AGENT_SERVICE_URL is the base URL of your deployed orchestrator Cloud Run
# service. NO trailing slash, NO path. This is also the audience the ID token
# is minted for, so it must match exactly.
AGENT_SERVICE_URL=https://your-orchestrator-service-url.run.app
AGENT_APP_NAME=orchestrator

# Optional — Google AI Studio key for the report banner illustration
# (app/api/banner/route.ts, gemini-2.5-flash-image). Unset it and the app
# skips the banner entirely; nothing else is affected. Free key at
# https://aistudio.google.com/apikey. Server-side only.
GEMINI_API_KEY=

# Optional — public deployed URL, used to build the Open Graph share image.
# Safe to expose to the browser. Defaults to localhost in dev.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional — GA4 measurement ID (Admin > Data streams > your web stream).
# Safe to expose to the browser — a public tag id, not a secret. Unset it
# and gtag.js never loads; no analytics run.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
